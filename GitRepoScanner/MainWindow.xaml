<Window x:Class="GitRepoScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GitRepoScanner.Converters"
        Title="Git Repo Scanner"
        Height="640" Width="980"
        MinHeight="420" MinWidth="660"
        WindowStartupLocation="CenterScreen"
        Background="#F8F9FA"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <conv:BoolToVisibilityConverter          x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter   x:Key="InvBoolToVis"/>
        <conv:StringToVisibilityConverter        x:Key="StringToVis"/>
        <conv:FileStatusToColorConverter         x:Key="StatusColor"/>

        <!-- Rounded button template -->
        <ControlTemplate x:Key="RoundedBtnTpl" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Height"           Value="30"/>
            <Setter Property="Padding"          Value="14,0"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template"         Value="{StaticResource RoundedBtnTpl}"/>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Height"   Value="26"/>
            <Setter Property="Padding"  Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Subtle badge base -->
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="4"/>
            <Setter Property="Padding"          Value="7,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"           Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ TOOLBAR ═══ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel LastChildFill="True">
                <!-- Right-side buttons first so DockPanel fills TextBox correctly -->
                <Button DockPanel.Dock="Right"
                        Content="↻  Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#16A34A" BorderBrush="#15803D" Foreground="White"/>
                <Button DockPanel.Dock="Right"
                        Content="⌕  Scan"
                        Command="{Binding ScanCommand}"
                        Style="{StaticResource ToolbarBtn}"
                        Background="#2563EB" BorderBrush="#1D4ED8" Foreground="White"
                        Margin="0,0,8,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Browse…"
                        Command="{Binding BrowseCommand}"
                        Style="{StaticResource ToolbarBtn}"
                        Background="White" BorderBrush="#D1D5DB" Foreground="#374151"
                        Margin="0,0,8,0"/>
                <TextBlock DockPanel.Dock="Left"
                           Text="Root path"
                           VerticalAlignment="Center"
                           FontSize="12" Foreground="#6B7280"
                           Margin="0,0,8,0"/>
                <TextBox Text="{Binding RootPath, UpdateSourceTrigger=LostFocus}"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         FontFamily="Consolas" FontSize="12"
                         BorderBrush="#D1D5DB" BorderThickness="1"
                         Margin="0,0,8,0"/>
            </DockPanel>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="1"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1"
                Padding="14,5">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="6" Height="6" Fill="#16A34A" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="11" Foreground="#6B7280" VerticalAlignment="Center"/>

                <TextBlock FontSize="11" Foreground="#9CA3AF" Margin="10,0,0,0" VerticalAlignment="Center"
                           Visibility="{Binding LastScanned, Converter={StaticResource StringToVis}}">
                    <Run Text="|  Last scanned: "/><Run Text="{Binding LastScanned}"/>
                </TextBlock>

                <TextBlock FontSize="11" Foreground="#9CA3AF" Margin="10,0,0,0" VerticalAlignment="Center"
                           Visibility="{Binding LastRefreshed, Converter={StaticResource StringToVis}}">
                    <Run Text="|  Last refreshed: "/><Run Text="{Binding LastRefreshed}"/>
                </TextBlock>

                <Border Background="#EFF6FF" CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Working…" FontSize="11" Foreground="#1D4ED8"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ REPO LIST ═══ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Empty state -->
                <Border Padding="0,60"
                        Visibility="{Binding HasNoRepos, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No repositories found"
                                   FontSize="15" Foreground="#9CA3AF"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Set a root path above and click Scan to discover git repositories."
                                   FontSize="12" Foreground="#D1D5DB"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Repos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                <StackPanel>

                                    <!-- ── Repo header row ── -->
                                    <Border Padding="14,10" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding ToggleExpandCommand}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Folder icon -->
                                            <TextBlock Grid.Column="0"
                                                       Text="&#xE8B7;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="24" Foreground="#FFB900"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>

                                            <!-- Name + path (row 1), branch (row 2) -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding Name, Mode=OneWay}" FontSize="13" FontWeight="Medium"/>
                                                    <Run Text="  " FontSize="11"/>
                                                    <Run Text="{Binding Path, Mode=OneWay}" FontSize="11"
                                                         Foreground="#6B7280" FontFamily="Consolas"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="loading…" FontSize="11" Foreground="#9CA3AF"
                                                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">
                                                        <Run Text="⎇ " Foreground="#9CA3AF" FontSize="11"/>
                                                        <Run Text="{Binding CurrentBranch}" FontSize="11"
                                                             Foreground="#1D4ED8" FontFamily="Consolas"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Meta: loading / branch / count / open / chevron -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="10,0,0,0">

                                                <!-- Dirty badge (file count) -->
                                                <Border Style="{StaticResource Badge}"
                                                        Background="#FEF9C3" BorderBrush="#FDE68A"
                                                        Visibility="{Binding ShowDirtyBadge, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock FontSize="11" Foreground="#92400E">
                                                        <Run Text="{Binding FileCount, Mode=OneWay}"/>
                                                        <Run Text=" files"/>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Clean badge -->
                                                <Border Style="{StaticResource Badge}"
                                                        Background="#F0FDF4" BorderBrush="#BBF7D0"
                                                        Visibility="{Binding ShowCleanBadge, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="✓ clean" FontSize="11" Foreground="#166534"/>
                                                </Border>

                                                <!-- Open folder button -->
                                                <Button Content="📁 Open"
                                                        Command="{Binding OpenFolderCommand}"
                                                        Style="{StaticResource SmallBtn}"
                                                        Background="White" BorderBrush="#D1D5DB"
                                                        Foreground="#6B7280"
                                                        Margin="0,0,8,0"/>

                                                <!-- Expand chevron -->
                                                <TextBlock Text="›"
                                                           FontSize="20" Foreground="#9CA3AF"
                                                           VerticalAlignment="Center"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <RotateTransform Angle="0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="90"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- ── File list (collapsible) ── -->
                                    <Border Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                            Background="#F9FAFB"
                                            BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                                            Padding="46,8,14,10">
                                        <StackPanel>
                                            <TextBlock Text="No uncommitted changes."
                                                       FontSize="12" Foreground="#9CA3AF"
                                                       Visibility="{Binding IsClean, Converter={StaticResource BoolToVis}}"/>

                                            <ItemsControl ItemsSource="{Binding UncommittedFiles}"
                                                          Visibility="{Binding IsClean, Converter={StaticResource InvBoolToVis}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="{Binding Status, Converter={StaticResource StatusColor}}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       FontFamily="Consolas"
                                                                       Width="24" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding FilePath}"
                                                                       FontSize="12" FontFamily="Consolas"
                                                                       Foreground="#374151"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ BOTTOM BAR ═══ -->
        <Border Grid.Row="3"
                Background="#F9FAFB"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                Padding="14,5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           FontSize="11" Foreground="#9CA3AF"
                           VerticalAlignment="Center"
                           Visibility="{Binding LastRefreshed, Converter={StaticResource StringToVis}}">
                    <Run Text="Last refreshed: "/><Run Text="{Binding LastRefreshed}"/>
                </TextBlock>
                <TextBlock FontSize="11" Foreground="#C4C9D4"
                           VerticalAlignment="Center"
                           Text="repos.json  •  settings.json  (saved next to exe)"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
